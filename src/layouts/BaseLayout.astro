---
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  path: string;
}

const { lang, path } = Astro.props;
const t = useTranslations(lang);

const site = Astro.site ?? new URL('https://example.com');
const canonical = new URL(path, site).href;
const enUrl = new URL('/', site).href;
const zhUrl = new URL('/zh/', site).href;
const ogImage = new URL('/og.png', site).href;

const htmlLang = lang === 'zh' ? 'zh-CN' : 'en';
const ogLocale = lang === 'zh' ? 'zh_CN' : 'en_US';

const title = t('meta.title');
const description = t('meta.description');

const faq = [1, 2, 3, 4].map((i) => ({
  '@type': 'Question',
  name: t(`faq.q${i}`),
  acceptedAnswer: { '@type': 'Answer', text: t(`faq.a${i}`) },
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: t('nav.title'),
      alternateName: ['Fuck Claude', 'fuckclaude.xyz'],
      url: canonical,
      description,
      applicationCategory: 'SecurityApplication',
      operatingSystem: 'All',
      inLanguage: htmlLang,
      image: ogImage,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      featureList: [
        t('signal.timezone.name'),
        t('signal.language.name'),
        t('signal.fonts.name'),
        t('signal.intlLocale.name'),
        t('signal.timezoneOffset.name'),
        t('signal.emoji.name'),
      ],
    },
    { '@type': 'FAQPage', mainEntity: faq },
  ],
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#FAF9F5" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://cloud.umami.is" />
    <link rel="preload" as="image" href="/mascot/ceo-doze.webp" type="image/webp" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="zh-CN" href={zhUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={t('nav.title')} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={t('hero.title')} />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script defer src="https://cloud.umami.is/script.js" data-website-id="9c3fb106-8bd0-4243-b635-813f76398e11"></script>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />

    <style is:global>
      :root {
        --bg: #f8f5ef;
        --bg-soft: #ebe7de;
        --surface: #ffffff;
        --surface-2: #f0f4f1;
        --border: rgba(41, 38, 32, 0.12);
        --border-strong: rgba(41, 38, 32, 0.22);
        --ink: #171614;
        --text: #201f1c;
        --muted: #63615b;
        --muted-2: #8a887f;
        --accent: #d76044;
        --accent-strong: #b9462e;
        --accent-soft: rgba(215, 96, 68, 0.12);
        --teal: #2f8d83;
        --low: #3f8f66;
        --medium: #c38a20;
        --high: #c94b3e;
        --shadow-sm: 0 1px 1px rgba(26, 24, 20, 0.04), 0 6px 18px rgba(26, 24, 20, 0.06);
        --shadow-md: 0 1px 2px rgba(26, 24, 20, 0.06), 0 18px 48px rgba(26, 24, 20, 0.11);
        --shadow-lg: 0 12px 44px rgba(28, 25, 20, 0.13), 0 1px 0 rgba(255, 255, 255, 0.7) inset;
        --radius: 8px;
        --radius-sm: 8px;
        --maxw: 1040px;
        --font:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial,
          'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
        --serif: 'Georgia', 'Times New Roman', 'Songti SC', 'STSong', 'SimSun', serif;
        --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, 'Liberation Mono', monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: var(--font);
        color: var(--text);
        background:
          linear-gradient(180deg, rgba(47, 141, 131, 0.08), transparent 340px),
          linear-gradient(115deg, rgba(215, 96, 68, 0.12), transparent 38%),
          var(--bg);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        min-height: 100vh;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        z-index: -1;
        opacity: 0.36;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(32, 31, 28, 0.045) 1px, transparent 1px),
          linear-gradient(90deg, rgba(32, 31, 28, 0.04) 1px, transparent 1px);
        background-size: 42px 42px;
        mask-image: linear-gradient(to bottom, #000 0, transparent 72%);
      }

      a {
        color: var(--accent-strong);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      :focus-visible {
        outline: 3px solid color-mix(in srgb, var(--teal) 55%, white);
        outline-offset: 4px;
      }

      .wrap {
        width: 100%;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 0 20px;
      }

      .skip-link {
        position: fixed;
        left: 18px;
        top: 14px;
        z-index: 100;
        transform: translateY(-140%);
        padding: 8px 12px;
        border-radius: 8px;
        background: var(--ink);
        color: #fff;
        font-weight: 700;
        box-shadow: var(--shadow-md);
        transition: transform 0.2s ease;
      }
      .skip-link:focus {
        transform: translateY(0);
        text-decoration: none;
      }

      /* ---------- nav ---------- */
      .nav {
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(18px) saturate(1.2);
        background: rgba(248, 245, 239, 0.76);
        border-bottom: 1px solid var(--border);
        box-shadow: 0 1px 0 rgba(255, 255, 255, 0.65) inset;
      }
      .nav__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        height: 60px;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 760;
        color: var(--text);
        font-size: 0.98rem;
        letter-spacing: 0;
      }
      .brand:hover {
        text-decoration: none;
      }
      .brand svg {
        width: 28px;
        height: 28px;
        flex: none;
        color: var(--accent);
        filter: drop-shadow(0 6px 14px rgba(215, 96, 68, 0.24));
        transition: transform 0.28s ease;
      }
      .brand:hover svg {
        transform: translateY(-1px) rotate(-4deg);
      }
      .nav__actions {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .lang-toggle {
        display: inline-flex;
        border: 1px solid var(--border);
        border-radius: 999px;
        overflow: hidden;
        font-size: 0.82rem;
        background: rgba(255, 255, 255, 0.7);
        box-shadow: var(--shadow-sm);
      }
      .lang-toggle a {
        padding: 6px 13px;
        color: var(--muted);
        line-height: 1.45;
        transition:
          color 0.2s ease,
          background 0.2s ease;
      }
      .lang-toggle a:hover {
        text-decoration: none;
        color: var(--text);
      }
      .lang-toggle a[aria-current='page'] {
        background: var(--ink);
        color: #fff;
        font-weight: 650;
      }
      .icon-link {
        display: inline-flex;
        color: var(--muted);
      }
      .icon-link:hover {
        color: var(--text);
      }

      /* ---------- hero ---------- */
      .hero {
        position: relative;
        isolation: isolate;
        text-align: center;
        padding: clamp(30px, 6vw, 58px) 0 12px;
      }
      .hero__field {
        position: absolute;
        inset: 0;
        z-index: -1;
        overflow: hidden;
        pointer-events: none;
      }
      .hero__field span {
        position: absolute;
        left: 50%;
        top: 54%;
        width: min(72vw, 760px);
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(47, 141, 131, 0.36), transparent);
        transform-origin: 50% 50%;
        animation: field-drift 10s ease-in-out infinite;
      }
      .hero__field span:nth-child(1) {
        transform: translateX(-50%) rotate(-10deg);
      }
      .hero__field span:nth-child(2) {
        top: 64%;
        animation-delay: -3s;
        background: linear-gradient(90deg, transparent, rgba(215, 96, 68, 0.32), transparent);
        transform: translateX(-50%) rotate(8deg);
      }
      .hero__field span:nth-child(3) {
        top: 38%;
        width: min(62vw, 560px);
        animation-delay: -6s;
        transform: translateX(-50%) rotate(0deg);
      }
      @keyframes field-drift {
        0%,
        100% {
          opacity: 0.35;
          translate: 0 0;
        }
        50% {
          opacity: 0.72;
          translate: 0 -10px;
        }
      }
      .hero h1 {
        font-family: var(--serif);
        font-size: clamp(2.2rem, 5.6vw, 4.25rem);
        line-height: 1.16;
        margin: 0 auto;
        max-width: 22ch;
        letter-spacing: 0;
        font-weight: 700;
        text-wrap: balance;
        animation: hero-rise 0.58s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      @keyframes hero-rise {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }
      .hero .accent {
        color: var(--accent-strong);
        font-style: italic;
      }
      .trust {
        list-style: none;
        margin: 18px auto 0;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 8px;
      }
      .trust li {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.82rem;
        font-weight: 650;
        color: var(--muted);
        border: 1px solid rgba(47, 141, 131, 0.16);
        border-radius: 999px;
        padding: 6px 13px 6px 8px;
        background: rgba(255, 255, 255, 0.68);
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.78) inset,
          0 8px 18px rgba(31, 30, 29, 0.04);
        transition:
          transform 0.18s ease,
          border-color 0.18s ease,
          background 0.18s ease;
      }
      .trust li:hover {
        transform: translateY(-1px);
        border-color: color-mix(in srgb, var(--teal) 34%, var(--border));
        background: rgba(255, 255, 255, 0.86);
      }
      .trust__icon {
        display: inline-grid;
        place-items: center;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        color: var(--teal);
        background:
          linear-gradient(180deg, rgba(47, 141, 131, 0.13), rgba(47, 141, 131, 0.06)),
          #fff;
        box-shadow: 0 0 0 1px rgba(47, 141, 131, 0.16) inset;
        flex: none;
      }
      .trust__icon svg {
        width: 14px;
        height: 14px;
      }

      /* ---------- credit banner ---------- */
      .credit {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        margin-bottom: 14px;
        padding: 8px 16px;
        border-radius: 999px;
        font-size: 0.84rem;
        font-weight: 600;
        color: #2d6f69;
        border: 1px solid color-mix(in srgb, var(--teal) 30%, var(--border));
        background: rgba(255, 255, 255, 0.75);
        box-shadow: var(--shadow-sm);
        animation: hero-rise 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.08s both;
      }
      .credit__spark {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--teal);
        animation: credit-pulse 1.8s ease-in-out infinite;
        flex: none;
      }
      @keyframes credit-pulse {
        0%,
        100% {
          transform: scale(1);
          opacity: 1;
        }
        50% {
          transform: scale(1.45);
          opacity: 0.55;
        }
      }

      /* ---------- score panel ---------- */
      .panel {
        position: relative;
        overflow: hidden;
        --mx: 50%;
        --my: 35%;
        margin: 24px auto 0;
        padding: clamp(22px, 4vw, 34px);
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(255, 255, 255, 0.8)),
          var(--surface);
        border: 1px solid rgba(255, 255, 255, 0.72);
        border-radius: var(--radius);
        box-shadow: var(--shadow-lg);
        text-align: center;
        animation: panel-in 0.64s cubic-bezier(0.16, 1, 0.3, 1) 0.12s both;
      }
      .panel::before {
        content: '';
        position: absolute;
        inset: 0;
        pointer-events: none;
        border-radius: inherit;
        box-shadow: 0 0 0 1px rgba(41, 38, 32, 0.08) inset;
      }
      .panel::after {
        content: '';
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0;
        background: radial-gradient(
          circle 220px at var(--mx) var(--my),
          rgba(47, 141, 131, 0.12),
          transparent 64%
        );
        transition: opacity 0.25s ease;
      }
      .panel:hover::after {
        opacity: 1;
      }
      .panel[data-band='low'] {
        border-color: color-mix(in srgb, var(--low) 22%, rgba(255, 255, 255, 0.72));
        box-shadow:
          0 12px 44px rgba(63, 143, 102, 0.14),
          0 1px 0 rgba(255, 255, 255, 0.7) inset;
      }
      .panel[data-band='medium'] {
        border-color: color-mix(in srgb, var(--medium) 24%, rgba(255, 255, 255, 0.72));
        box-shadow:
          0 12px 44px rgba(195, 138, 32, 0.16),
          0 1px 0 rgba(255, 255, 255, 0.7) inset;
      }
      .panel[data-band='high'] {
        border-color: color-mix(in srgb, var(--high) 24%, rgba(255, 255, 255, 0.72));
        box-shadow:
          0 12px 44px rgba(201, 75, 62, 0.16),
          0 1px 0 rgba(255, 255, 255, 0.7) inset;
      }
      .panel__grid {
        position: absolute;
        inset: 0;
        opacity: 0.45;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(47, 141, 131, 0.08) 1px, transparent 1px),
          linear-gradient(90deg, rgba(215, 96, 68, 0.07) 1px, transparent 1px);
        background-size: 24px 24px;
        mask-image: linear-gradient(to bottom, #000, transparent 78%);
      }
      .panel__progress {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        z-index: 2;
        height: 3px;
        overflow: hidden;
        background: rgba(32, 31, 28, 0.05);
        opacity: 0;
        transition: opacity 0.24s ease;
      }
      .panel[data-progress='active'] .panel__progress,
      .panel[data-progress='done'] .panel__progress {
        opacity: 1;
      }
      .panel[data-progress='done'] .panel__progress {
        opacity: 0;
        transition-delay: 0.5s;
      }
      #scan-progress-bar {
        --progress: 0;
        display: block;
        width: calc(var(--progress) * 100%);
        height: 100%;
        min-width: 0;
        background: linear-gradient(90deg, var(--teal), var(--accent), var(--high));
        box-shadow: 0 0 18px rgba(215, 96, 68, 0.35);
        transition: width 0.52s cubic-bezier(0.16, 1, 0.3, 1);
      }
      @keyframes panel-in {
        from {
          opacity: 0;
          transform: translateY(16px) scale(0.985);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }
      .panel__main {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: clamp(16px, 4vw, 56px);
        flex-wrap: wrap;
      }
      .gauge {
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .gauge__ring {
        position: relative;
        width: clamp(190px, 24vw, 224px);
        height: clamp(190px, 24vw, 224px);
        filter: drop-shadow(0 18px 30px rgba(39, 35, 28, 0.1));
      }
      .gauge__ring svg {
        width: 100%;
        height: 100%;
        transform: rotate(-90deg);
      }
      .gauge__track {
        fill: none;
        stroke: rgba(32, 31, 28, 0.08);
        stroke-width: 14;
      }
      #score-ring {
        fill: none;
        stroke: var(--accent);
        stroke-width: 14;
        stroke-linecap: round;
        transition:
          stroke-dashoffset 1s cubic-bezier(0.16, 1, 0.3, 1),
          stroke 0.6s ease;
      }
      #score-gauge[data-scanning='true'] #score-ring {
        animation: ring-glow 1.1s ease-in-out infinite;
      }
      @keyframes ring-glow {
        0%,
        100% {
          filter: drop-shadow(0 0 0 rgba(215, 96, 68, 0));
        }
        50% {
          filter: drop-shadow(0 0 9px rgba(215, 96, 68, 0.45));
        }
      }
      #score-gauge[data-band='low'] #score-ring {
        stroke: var(--low);
      }
      #score-gauge[data-band='medium'] #score-ring {
        stroke: var(--medium);
      }
      #score-gauge[data-band='high'] #score-ring {
        stroke: var(--high);
      }
      .gauge__center {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
        border-radius: 999px;
        margin: 34px;
        background: rgba(255, 255, 255, 0.58);
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.75) inset,
          0 10px 30px rgba(32, 31, 28, 0.06);
      }
      .gauge__num {
        font-family: var(--serif);
        font-size: clamp(3.2rem, 7vw, 4rem);
        font-weight: 700;
        line-height: 1;
        font-variant-numeric: tabular-nums;
        letter-spacing: 0;
      }
      .gauge__outof {
        color: var(--muted-2);
        font-size: 0.9rem;
        font-family: var(--mono);
      }
      .risk-badge {
        margin-top: 18px;
        display: inline-block;
        padding: 7px 18px;
        border-radius: 999px;
        font-weight: 650;
        font-size: 0.95rem;
        border: 1px solid var(--border);
        color: var(--muted);
        background: rgba(255, 255, 255, 0.74);
        box-shadow: var(--shadow-sm);
        transition:
          color 0.24s ease,
          border-color 0.24s ease,
          background 0.24s ease,
          transform 0.24s ease;
      }
      .risk-badge[data-band] {
        transform: translateY(-1px);
      }
      .risk-badge[data-band='low'] {
        color: var(--low);
        border-color: color-mix(in srgb, var(--low) 40%, transparent);
        background: color-mix(in srgb, var(--low) 10%, var(--surface));
      }
      .risk-badge[data-band='medium'] {
        color: var(--medium);
        border-color: color-mix(in srgb, var(--medium) 40%, transparent);
        background: color-mix(in srgb, var(--medium) 10%, var(--surface));
      }
      .risk-badge[data-band='high'] {
        color: var(--high);
        border-color: color-mix(in srgb, var(--high) 40%, transparent);
        background: color-mix(in srgb, var(--high) 10%, var(--surface));
      }
      .risk-desc {
        margin: 12px auto 0;
        color: var(--muted);
        max-width: 46ch;
        min-height: 1.6em;
        font-size: 1.02rem;
      }

      /* ---------- big scan button ---------- */
      .scan-btn {
        position: relative;
        overflow: hidden;
        margin-top: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 15px 40px;
        border-radius: 999px;
        border: none;
        background: linear-gradient(135deg, var(--ink), #34302a);
        color: #fff;
        font: inherit;
        font-size: 1.08rem;
        font-weight: 650;
        cursor: pointer;
        transform: translateZ(0);
        box-shadow:
          0 2px 8px rgba(32, 31, 28, 0.28),
          0 14px 30px rgba(32, 31, 28, 0.18);
        transition:
          transform 0.16s ease,
          box-shadow 0.22s ease,
          filter 0.22s ease;
      }
      .scan-btn::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(110deg, transparent 0 34%, rgba(255, 255, 255, 0.2) 48%, transparent 62% 100%);
        transform: translateX(-120%);
        transition: transform 0.62s ease;
      }
      .scan-btn span,
      .scan-btn svg {
        position: relative;
        z-index: 1;
      }
      .scan-btn:focus-visible {
        outline-color: color-mix(in srgb, var(--accent) 65%, white);
        outline-offset: 5px;
      }
      .scan-btn:hover {
        transform: translateY(-1px);
        filter: saturate(1.08);
        box-shadow:
          0 4px 12px rgba(32, 31, 28, 0.3),
          0 18px 36px rgba(32, 31, 28, 0.2);
      }
      .scan-btn:hover::after {
        transform: translateX(120%);
      }
      .scan-btn:active {
        transform: scale(0.98);
      }
      .scan-btn:disabled {
        opacity: 0.68;
        cursor: default;
        transform: none;
      }
      .scan-btn:disabled svg {
        animation: spin 0.9s linear infinite;
      }
      .scan-btn svg {
        width: 18px;
        height: 18px;
      }

      /* ---------- sections ---------- */
      section {
        padding: 34px 0;
      }
      .deferred-section {
        content-visibility: auto;
        contain-intrinsic-size: 1px 420px;
      }
      .section-head {
        margin-bottom: 18px;
      }
      .section-head,
      .prose,
      .faq details,
      .privacy {
        opacity: 0;
        transform: translateY(14px);
        transition:
          opacity 0.58s cubic-bezier(0.16, 1, 0.3, 1),
          transform 0.58s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .section-head.is-visible,
      .prose.is-visible,
      .faq details.is-visible,
      .privacy.is-visible {
        opacity: 1;
        transform: none;
      }
      .faq details:nth-child(2) {
        transition-delay: 0.04s;
      }
      .faq details:nth-child(3) {
        transition-delay: 0.08s;
      }
      .faq details:nth-child(4) {
        transition-delay: 0.12s;
      }
      .section-head h2 {
        font-family: var(--serif);
        font-size: clamp(1.45rem, 3vw, 1.8rem);
        margin: 0 0 6px;
        letter-spacing: 0;
        color: var(--ink);
        text-shadow: 0 1px 0 rgba(255, 255, 255, 0.55);
      }
      .section-head p {
        margin: 0;
        color: color-mix(in srgb, var(--text) 72%, var(--muted));
        font-size: 0.95rem;
      }

      /* ---------- result chips ---------- */
      .result {
        margin: 20px auto 0;
        max-width: 640px;
        position: relative;
        z-index: 1;
        animation: result-in 0.44s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      @keyframes result-in {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }
      .result__title {
        margin: 0 0 12px;
        font-size: 0.92rem;
        color: var(--muted);
      }
      .result__hits {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: center;
        align-items: center;
      }
      .chip {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.85rem;
        line-height: 1.35;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.76);
        box-shadow: var(--shadow-sm);
        animation: chip-in 0.36s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      .chip:nth-child(2) {
        animation-delay: 0.04s;
      }
      .chip:nth-child(3) {
        animation-delay: 0.08s;
      }
      .chip:nth-child(4) {
        animation-delay: 0.12s;
      }
      .chip:nth-child(5) {
        animation-delay: 0.16s;
      }
      .chip:nth-child(6) {
        animation-delay: 0.2s;
      }
      .chip b {
        font-family: var(--mono);
        white-space: nowrap;
      }
      .chip__icon {
        display: inline-flex;
        width: 15px;
        height: 15px;
      }
      .chip__icon svg {
        width: 15px;
        height: 15px;
      }
      .chip[data-verdict='high'] {
        color: var(--high);
        border-color: color-mix(in srgb, var(--high) 40%, transparent);
        background: color-mix(in srgb, var(--high) 8%, var(--surface));
      }
      .chip[data-verdict='medium'] {
        color: var(--medium);
        border-color: color-mix(in srgb, var(--medium) 40%, transparent);
        background: color-mix(in srgb, var(--medium) 8%, var(--surface));
      }
      @keyframes chip-in {
        from {
          opacity: 0;
          transform: translateY(6px) scale(0.96);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }

      /* ---------- scan list ---------- */
      .scan-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .scan-row {
        position: relative;
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 15px 16px;
        border-radius: var(--radius-sm);
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        opacity: 0.78;
        transform: translateY(4px);
        scroll-margin: 94px;
        animation: row-in 0.52s cubic-bezier(0.16, 1, 0.3, 1) both;
        transition:
          opacity 0.4s,
          transform 0.4s,
          border-color 0.3s,
          background 0.3s,
          box-shadow 0.3s;
      }
      .scan-row:nth-child(2) {
        animation-delay: 0.04s;
      }
      .scan-row:nth-child(3) {
        animation-delay: 0.08s;
      }
      .scan-row:nth-child(4) {
        animation-delay: 0.12s;
      }
      .scan-row:nth-child(5) {
        animation-delay: 0.16s;
      }
      .scan-row:nth-child(6) {
        animation-delay: 0.2s;
      }
      @keyframes row-in {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 0.78;
          transform: translateY(4px);
        }
      }
      .scan-row:hover {
        background: rgba(255, 255, 255, 0.92);
        box-shadow: var(--shadow-md);
        transform: translateY(0);
      }
      .scan-row.is-active {
        opacity: 1;
        transform: none;
        border-color: color-mix(in srgb, var(--accent) 55%, var(--border));
        background: rgba(255, 255, 255, 0.96);
        box-shadow: var(--shadow-md);
      }
      .scan-row.is-done {
        opacity: 1;
        transform: none;
      }
      .scan-row::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background: transparent;
      }
      .scan-row[data-verdict='low']::before {
        background: var(--low);
      }
      .scan-row[data-verdict='medium']::before {
        background: var(--medium);
      }
      .scan-row[data-verdict='high']::before {
        background: var(--high);
      }
      .scan-row.is-active::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(
          90deg,
          transparent,
          color-mix(in srgb, var(--accent) 16%, transparent),
          transparent
        );
        transform: translateX(-100%);
        animation: scan-sweep 1s ease-in-out infinite;
      }
      @keyframes scan-sweep {
        to {
          transform: translateX(100%);
        }
      }
      .scan-row__icon {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        background: var(--accent-soft);
        border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--border));
        color: var(--accent-strong);
        flex: none;
        z-index: 1;
      }
      .scan-row.is-active .scan-row__icon {
        animation: icon-pulse 1s ease-in-out infinite;
      }
      @keyframes icon-pulse {
        0%,
        100% {
          transform: scale(1);
        }
        50% {
          transform: scale(1.06);
        }
      }
      .scan-row__icon svg {
        width: 20px;
        height: 20px;
      }
      .scan-row__main {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
        z-index: 1;
      }
      .scan-row__name {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        font-weight: 720;
        font-size: 0.98rem;
        color: var(--text);
      }
      .scan-row__desc {
        font-size: 0.82rem;
        color: color-mix(in srgb, var(--text) 62%, var(--muted));
      }
      .scan-row__status {
        display: flex;
        align-items: center;
        gap: 10px;
        flex: none;
        z-index: 1;
        min-width: 142px;
        justify-content: flex-end;
      }
      .scan-row__value {
        font-family: var(--mono);
        font-size: 0.82rem;
        color: color-mix(in srgb, var(--text) 68%, var(--muted));
        max-width: 30vw;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        border-radius: 7px;
        transition:
          color 0.22s ease,
          background 0.22s ease,
          padding 0.22s ease;
      }
      .scan-row.is-done .scan-row__value:not(:empty) {
        padding: 2px 7px;
        background: rgba(32, 31, 28, 0.045);
        color: color-mix(in srgb, var(--text) 76%, var(--muted));
      }
      .scan-row__contrib {
        font-family: var(--mono);
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--text);
        min-width: 30px;
        text-align: right;
        font-variant-numeric: tabular-nums;
      }
      .scan-row.is-done .scan-row__contrib {
        animation: contrib-pop 0.34s cubic-bezier(0.34, 1.56, 0.64, 1) both;
      }
      @keyframes contrib-pop {
        from {
          opacity: 0;
          transform: translateY(4px) scale(0.9);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }
      .spinner {
        display: none;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        border: 2px solid var(--border-strong);
        border-top-color: var(--accent);
        animation: spin 0.7s linear infinite;
        flex: none;
      }
      .scan-row.is-active .spinner {
        display: inline-block;
      }
      .scan-row .dot {
        display: none;
      }
      .scan-row.is-done .dot {
        display: inline-block;
      }
      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }
      .badge {
        display: inline-block;
        font-size: 0.68rem;
        padding: 2px 8px;
        border-radius: 7px;
        border: 1px solid var(--border-strong);
        color: var(--muted);
        white-space: nowrap;
        line-height: 1.5;
        background: rgba(255, 255, 255, 0.72);
      }
      .badge--claude {
        color: #fff;
        background: var(--ink);
        border-color: var(--accent);
        font-weight: 650;
      }
      .dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--muted-2);
        flex: none;
        transition: background 0.3s;
      }
      .dot--low {
        background: var(--low);
      }
      .dot--medium {
        background: var(--medium);
      }
      .dot--high {
        background: var(--high);
      }

      /* ---------- how + faq ---------- */
      .prose {
        max-width: 76ch;
        padding: 20px;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: rgba(255, 255, 255, 0.58);
        box-shadow: var(--shadow-sm);
      }
      .prose p {
        margin: 0 0 14px;
        color: var(--muted);
        font-size: 0.97rem;
      }
      .prose p:last-child {
        margin-bottom: 0;
      }

      .faq {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .faq details {
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        box-shadow: var(--shadow-sm);
        padding: 0 18px;
        transition:
          border-color 0.2s,
          background 0.2s,
          box-shadow 0.2s;
      }
      .faq details[open] {
        border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
        background: rgba(255, 255, 255, 0.92);
        box-shadow: var(--shadow-md);
      }
      .faq summary {
        cursor: pointer;
        list-style: none;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 0;
        font-weight: 620;
        font-size: 0.98rem;
      }
      .faq summary::-webkit-details-marker {
        display: none;
      }
      .faq summary::after {
        content: '+';
        font-family: var(--mono);
        font-size: 1.1rem;
        color: var(--accent-strong);
        flex: none;
        transition: transform 0.2s;
      }
      .faq details[open] summary::after {
        transform: rotate(45deg);
      }
      .faq details p {
        margin: 0;
        padding: 0 0 16px;
        color: var(--muted);
        font-size: 0.92rem;
      }

      /* ---------- privacy + footer ---------- */
      .privacy {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        padding: 16px 18px;
        border: 1px solid color-mix(in srgb, var(--low) 30%, var(--border));
        background:
          linear-gradient(135deg, color-mix(in srgb, var(--low) 8%, var(--surface)), rgba(255, 255, 255, 0.76));
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
      }
      .privacy svg {
        width: 22px;
        height: 22px;
        color: var(--low);
        flex: none;
        margin-top: 2px;
      }
      .privacy h2 {
        font-size: 1rem;
        margin: 0 0 4px;
      }
      .privacy p {
        margin: 0;
        color: color-mix(in srgb, var(--text) 70%, var(--muted));
        font-size: 0.9rem;
      }

      footer {
        border-top: 1px solid var(--border);
        margin-top: 30px;
        padding: 28px 0 44px;
        color: var(--muted-2);
        font-size: 0.85rem;
        background: var(--bg-soft);
      }
      .footer__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
      }
      .footer__disclaimer {
        margin: 0;
        max-width: 70ch;
      }
      .footer__contact {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        flex: none;
        padding: 7px 12px;
        border: 1px solid color-mix(in srgb, var(--teal) 25%, var(--border));
        border-radius: 999px;
        color: color-mix(in srgb, var(--text) 74%, var(--teal));
        background: rgba(255, 255, 255, 0.55);
        box-shadow: var(--shadow-sm);
        font-weight: 700;
        transition:
          transform 0.18s ease,
          background 0.18s ease,
          border-color 0.18s ease;
      }
      .footer__contact:hover {
        transform: translateY(-1px);
        text-decoration: none;
        background: rgba(255, 255, 255, 0.8);
        border-color: color-mix(in srgb, var(--teal) 42%, var(--border));
      }
      .footer__contact svg {
        width: 16px;
        height: 16px;
        color: var(--teal);
      }

      /* ---------- responsive ---------- */
      @media (max-width: 560px) {
        .hero {
          padding-top: 22px;
        }
        .panel {
          padding: 20px 14px 18px;
        }
        .panel__main {
          gap: 8px;
        }
        .gauge__center {
          margin: 30px;
        }
        .scan-row {
          align-items: flex-start;
          gap: 11px;
          padding: 13px 12px;
        }
        .scan-row__desc {
          display: none;
        }
        .scan-row .badge:not(.badge--claude) {
          display: none;
        }
        .scan-row__value {
          max-width: 40vw;
        }
        .scan-row__status {
          gap: 7px;
          padding-top: 4px;
          min-width: 0;
          max-width: 43vw;
          flex-wrap: wrap;
        }
        .scan-btn {
          width: 100%;
        }
        .prose {
          padding: 16px;
        }
        .footer__inner {
          align-items: flex-start;
          flex-direction: column;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        * {
          scroll-behavior: auto !important;
          transition: none !important;
          animation: none !important;
        }
        .section-head,
        .prose,
        .faq details,
        .privacy {
          opacity: 1 !important;
          transform: none !important;
        }
      }
    </style>
  </body>
</html>
