    <p class="footer__disclaimer">{t('footer.disclaimer')}</p>
    <a class="footer__contact" href="https://t.me/huluwa561" target="_blank" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21.5 4.6 3.4 11.7c-1.2.5-1.2 1.2-.2 1.5l4.6 1.4 1.8 5.5c.2.6.4.8.8.8.4 0 .6-.2 1-.5l2.5-2.4 4.9 3.6c.9.5 1.5.3 1.7-.8l3-14.3c.3-1.3-.5-1.9-1.6-1.4Z"></path>
        <path d="m8 14.4 10.7-6.7"></path>
      </svg>
      <span>@huluwa561</span>
    </a>
  </div>
</footer>
